{
  "name": "dims-sr-desktop",
  "version": "1.0.0",
  "description": "DIMS-SR Desktop Application",
  "main": "public/electron.js",
  "homepage": "./",
  "scripts": {
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "react-test": "react-scripts test",
    "react-eject": "react-scripts eject",
    "electron-start": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && electron .\"",
    "electron-dev": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && electron . --dev\"",
    "electron-build": "npm run react-build && electron-builder",
    "build": "npm run react-build && npm run electron-build",
    "build-mac": "npm run react-build && electron-builder --mac",
    "build-win": "npm run react-build && electron-builder --win",
    "build-linux": "npm run react-build && electron-builder --linux"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.17.0",
    "axios": "^1.6.0",
    "electron-squirrel-startup": "^1.1.0",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "react-scripts": "5.0.1",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "electron-dev-updater": "^2.0.0",
    "wait-on": "^7.1.0",
    "concurrently": "^8.2.2"
  },
  "build": {
    "appId": "com.dims-sr.desktop",
    "productName": "DIMS-SR",
    "files": [
      "build/**/*",
      "public/electron.js",
      "public/preload.js",
      "node_modules/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Productivity"
    }
  }
}
