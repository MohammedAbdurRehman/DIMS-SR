    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.0",
    "fabric-ca-client": "^2.2.0",
    "fabric-network": "^2.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "pg": "^8.11.0",
    "speakeasy": "^2.0.0",
    "uuid": "^9.0.1"
