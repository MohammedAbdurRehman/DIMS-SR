# Server Configuration
PORT=3001
NODE_ENV=production
API_URL=https://localhost:3001

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=dims_user
DB_PASSWORD=secure_password_here
DB_NAME=dims_sr_db

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_long
JWT_EXPIRY=7d
REFRESH_TOKEN_SECRET=your_super_secret_refresh_token_key
REFRESH_TOKEN_EXPIRY=30d

# Session Configuration
SESSION_SECRET=your_session_secret_key_min_32_characters
SESSION_EXPIRY=24h
SECURE_COOKIES=true

# Hyperledger Fabric (see fabric/README.md)
# Production: leave enabled and configure paths below. Local UI-only: FABRIC_ENABLED=false
FABRIC_ENABLED=true
FABRIC_CONNECTION_PROFILE_PATH=/absolute/path/to/connection-profile.json
FABRIC_USER_CREDENTIALS_DIR=/absolute/path/to/wallet-user/msp
# Or: FABRIC_WALLET_PATH=/absolute/path/to/wallet
FABRIC_IDENTITY_LABEL=appUser
FABRIC_MSP_ID=Org1MSP
FABRIC_CHANNEL_NAME=mychannel
FABRIC_CHAINCODE_NAME=simregistry
FABRIC_DISCOVERY_AS_LOCALHOST=true

# NADRA: optional HTTP adapter. If unset, the API uses built-in mock citizens + mock fingerprint (FYP default).
# NADRA_API_BASE_URL=http://127.0.0.1:4000
NADRA_HTTP_TIMEOUT_MS=30000

# Security
CORS_ORIGIN=https://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# TLS/SSL Certificates (for HTTPS)
SSL_CERT_PATH=./certs/server.crt
SSL_KEY_PATH=./certs/server.key
